                  <div class="mh-audio-bar" style="--h:18px;--d:0.84s"></div>
                  <div class="mh-audio-bar" style="--h:32px;--d:0.91s"></div>
                  <div class="mh-audio-bar" style="--h:46px;--d:0.98s"></div>
                  <div class="mh-audio-bar" style="--h:24px;--d:1.05s"></div>
                  <div class="mh-audio-bar" style="--h:40px;--d:1.12s"></div>
                  <div class="mh-audio-bar" style="--h:34px;--d:1.19s"></div>
                  <div class="mh-audio-bar" style="--h:20px;--d:1.26s"></div>
                  <div class="mh-audio-bar" style="--h:38px;--d:1.33s"></div>
                </div>
              </div>
              <div class="mh-term-wave-freq">44.1 kHz · Calibrated</div>
            </div>

            <!-- Score dial -->
            <div class="mh-term-score-section">
              <div class="mh-term-score-label">STAR Method Structure</div>
              <div class="mh-dial-wrap">
                <svg width="88" height="88" viewBox="0 0 88 88" class="mh-dial-svg">
                  <!-- Track -->
                  <circle cx="44" cy="44" r="36" fill="none" stroke="#1E293B" stroke-width="6"/>
                  <!-- Progress arc — sweeps from top (270°) to 83% -->
                  <circle cx="44" cy="44" r="36" fill="none" stroke="#3B82F6" stroke-width="6"
                    stroke-linecap="round"
                    stroke-dasharray="226.195"
                    stroke-dashoffset="38.453"
                    class="mh-dial-arc"/>
                  <!-- Tick marks at 0°, 90°, 180°, 270° -->
                  <line x1="44" y1="10" x2="44" y2="6" stroke="#334155" stroke-width="1.5"/>
                  <line x1="78" y1="44" x2="82" y2="44" stroke="#334155" stroke-width="1.5"/>
                  <line x1="44" y1="78" x2="44" y2="82" stroke="#334155" stroke-width="1.5"/>
                  <line x1="10" y1="44" x2="6" y2="44" stroke="#334155" stroke-width="1.5"/>
