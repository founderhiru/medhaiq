                  <text x="44" y="38" text-anchor="middle" fill="#ffffff" font-family="Plus Jakarta Sans,sans-serif" font-size="18" font-weight="800">83</text>
                  <text x="44" y="50" text-anchor="middle" fill="#64748B" font-family="Inter,sans-serif" font-size="8" font-weight="500">STRUCTURE</text>
