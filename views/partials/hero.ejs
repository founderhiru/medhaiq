                  <div class="mh-audio-bar" style="--h:38px;--d:0.28s"></div>
                  <div class="mh-audio-bar" style="--h:44px;--d:0.35s"></div>
                  <div class="mh-audio-bar" style="--h:30px;--d:0.42s"></div>
                  <div class="mh-audio-bar" style="--h:22px;--d:0.49s"></div>
                  <div class="mh-audio-bar" style="--h:48px;--d:0.56s"></div>
