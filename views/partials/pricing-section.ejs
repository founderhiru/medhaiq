<script>
(function() {
  // ── State ─────────────────────────────────────────────
  var isAnnual = false;
  var currency = 'INR';

  // Base monthly prices (INR)
  var BASE_PRICES = { free: 0, professional: 999, leadership: 2999, executive: 7999 };

  // Annual equivalents (20% discount applied — shown as monthly breakdown)
  var ANNUAL_PRICES = { free: 0, professional: 799, leadership: 2399, executive: 6399 };
  var ANNUAL_TOTAL  = { professional: 9588, leadership: 28788, executive: 76788 };

  // Team / Enterprise — always annual, show monthly breakdown
  var TEAM_ANNUAL_INR   = 399999;
  var ENTERPRISE_ANNUAL_INR = 1249999;
  var TEAM_MONTHLY_INR   = Math.round(TEAM_ANNUAL_INR / 12);
  var ENTERPRISE_MONTHLY_INR = Math.round(ENTERPRISE_ANNUAL_INR / 12);

  // Currency conversion rates
  // USD base monthly prices
  var USD_PRICES_MONTHLY = { free: 0, professional: 12, leadership: 39, executive: 99 };
  var USD_TEAM_MONTHLY = Math.round(4999 / 12);   // ~416
  var USD_ENTERPRISE_MONTHLY = Math.round(14999 / 12); // ~1249

  // EUR equivalents (~0.92x USD)
  var EUR_PRICES_MONTHLY = { free: 0, professional: 11, leadership: 36, executive: 91 };
  var EUR_TEAM_MONTHLY = Math.round(4999 * 0.92 / 12);   // ~383
  var EUR_ENTERPRISE_MONTHLY = Math.round(14999 * 0.92 / 12); // ~1150

  // Currency symbols
  var CURRENCY_SYMBOLS = { INR: '\u20B9', USD: '$', EUR: '\u20AC' };

  // ── Helpers ─────────────────────────────────────────────
  function fmt(n) {
    if (currency === 'INR') {
      return n.toLocaleString('en-IN');
    }
    return n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function getPrice(tier) {
    var monthly = BASE_PRICES[tier] || 0;
    var price = isAnnual ? (ANNUAL_PRICES[tier] || 0) : monthly;
    if (currency === 'USD') {
      price = USD_PRICES_MONTHLY[tier] || 0;
      if (isAnnual) price = Math.round(price * 0.8);
    } else if (currency === 'EUR') {
      price = EUR_PRICES_MONTHLY[tier] || 0;
      if (isAnnual) price = Math.round(price * 0.8);
    }
    return price;
  }

  function getInstPrice(type) {
    if (currency === 'INR') {
      return type === 'team' ? TEAM_MONTHLY_INR : ENTERPRISE_MONTHLY_INR;
    }
    if (currency === 'USD') {
      return type === 'team' ? USD_TEAM_MONTHLY : USD_ENTERPRISE_MONTHLY;
    }
    return type === 'team' ? EUR_TEAM_MONTHLY : EUR_ENTERPRISE_MONTHLY;
  }

  // ── Update Individual Prices ──────────────────────────────
  function updateIndividualPrices() {
    var sym = CURRENCY_SYMBOLS[currency];

    // Free — always 0
    var freeVal = document.querySelector('[data-base="0"]');
    if (freeVal) freeVal.textContent = fmt(0);

    ['professional', 'leadership', 'executive'].forEach(function(tier) {
      var priceEl = document.querySelector('[data-base="' + BASE_PRICES[tier] + '"]');
      if (!priceEl) return;
      var price = getPrice(tier);
      priceEl.textContent = fmt(price);

      // Update currency symbol
      var symEl = priceEl.parentElement.querySelector('.mh-price-sym');
      if (symEl) symEl.innerHTML = sym;

      // Annual note
      var noteEl = document.getElementById('note-' + tier);
      if (noteEl) {
        if (isAnnual) {
          var annualTotal = ANNUAL_TOTAL[tier];
          if (currency === 'USD') annualTotal = Math.round(USD_PRICES_MONTHLY[tier] * 12 * 0.8);
          if (currency === 'EUR') annualTotal = Math.round(EUR_PRICES_MONTHLY[tier] * 12 * 0.8);
          noteEl.textContent = 'Billed \u20B9' + fmt(annualTotal) + '/year';
          noteEl.style.display = 'block';
        } else {
          noteEl.style.display = 'none';
        }
      }
    });

    // Update period label
    var periods = document.querySelectorAll('.mh-pricing-period');
    periods.forEach(function(el) {
      var card = el.closest('.mh-pricing-card');
      if (card && card.querySelector('[data-base="0"]')) return; // Free — no annual note
    });
  }

  // ── Update Institutional Prices ──────────────────────────
  function updateInstPrices() {
    var sym = CURRENCY_SYMBOLS[currency];
    var teamPrice = getInstPrice('team');
    var entPrice  = getInstPrice('enterprise');

    var teamEl = document.getElementById('inst-team-price');
    var entEl  = document.getElementById('inst-ent-price');

    if (teamEl) teamEl.textContent = fmt(teamPrice);
    if (entEl)  entEl.textContent  = fmt(entPrice);

    // Update symbols in inst cards
    document.querySelectorAll('.mh-inst-card .mh-price-sym').forEach(function(el) {
      el.innerHTML = sym;
    });
  }

  // ── Billing Toggle ───────────────────────────────────────
  var billingToggle = document.getElementById('billing-toggle');
  var billingThumb  = document.getElementById('billing-thumb');
  var saveBadge    = document.getElementById('save-badge');

  if (billingToggle) {
    billingToggle.addEventListener('click', function() {
      isAnnual = !isAnnual;
      if (isAnnual) {
        billingThumb.classList.add('mh-annual');
        saveBadge.style.display = 'inline';
      } else {
        billingThumb.classList.remove('mh-annual');
        saveBadge.style.display = 'none';
      }
      updateIndividualPrices();
    });
  }

  // ── Currency Selector ────────────────────────────────────
  var currencySelect = document.getElementById('currency-select');
  if (currencySelect) {
    currencySelect.addEventListener('change', function() {
      currency = currencySelect.value;
      updateIndividualPrices();
      updateInstPrices();
    });
  }

  // ── Tab Toggle ───────────────────────────────────────────
  var toggleInd = document.getElementById('toggle-individual');
  var toggleInst = document.getElementById('toggle-institutional');
  var tabInd = document.getElementById('tab-individual');
  var tabInst = document.getElementById('tab-institutional');

  if (toggleInd && toggleInst) {
    toggleInd.addEventListener('click', function() {
      toggleInd.classList.add('mh-toggle-active');
      toggleInst.classList.remove('mh-toggle-active');
      tabInd.style.display = 'block';
      tabInst.style.display = 'none';
    });
    toggleInst.addEventListener('click', function() {
      toggleInst.classList.add('mh-toggle-active');
      toggleInd.classList.remove('mh-toggle-active');
      tabInst.style.display = 'block';
      tabInd.style.display = 'none';
      updateInstPrices();
    });
  }

  // ── Modal logic (unchanged) ───────────────────────────────
  var ctas = document.querySelectorAll('[data-plan]');
  var modal = document.getElementById('mh-email-modal');
  var form = document.getElementById('mh-modal-form');
  var successDiv = document.getElementById('mh-modal-success');
  var planField = document.getElementById('mh-modal-plan');
  var submitBtn = document.getElementById('mh-modal-submit');
  var closeBtn = document.getElementById('mh-modal-close');
  var emailConfirm = document.getElementById('mh-modal-email-confirm');

  function openModal(plan) {
    modal.style.display = 'flex';
    planField.value = plan || '';
    form.style.display = 'flex';
    successDiv.style.display = 'none';
  }

  ctas.forEach(function(cta) {
    cta.addEventListener('click', function() {
      var plan = cta.getAttribute('data-plan');
      openModal(plan);
    });
  });

  if (closeBtn) {
    closeBtn.addEventListener('click', function() { modal.style.display = 'none'; });
  }
  if (modal) {
    modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });
  }

  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      var email = document.getElementById('mh-modal-email').value.trim();
      var name  = document.getElementById('mh-modal-name').value.trim();
      var role  = document.getElementById('mh-modal-role').value;
      var plan  = planField.value;
      if (!email || !/^[^\u0040@\u002E]+@[^\u0040@\u002E]+\u002E[^\u0040@\u002E]+$/.test(email)) {
        alert('Please enter a valid email address.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Claim My Priority Spot';
        return;
      }
      var data = { email: email, name: name || null, role: role || null, user_type: role || 'other', plan_interest: plan };
      try {
        var res  = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        var json = await res.json();
        if (json.success) {
          form.style.display = 'none';
          successDiv.style.display = 'block';
          if (emailConfirm) emailConfirm.textContent = email;
        } else {
          alert(json.error || 'Something went wrong. Please try again.');
        }
      } catch(err) {
        alert('Network error. Please try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Claim My Priority Spot';
      }
    });
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
      modal.style.display = 'none';
    }
  });

  // Initial render
  updateIndividualPrices();
})();
</script>