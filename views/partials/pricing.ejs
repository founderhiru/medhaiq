<script>
(function() {
  var btnINR = document.getElementById('mh-toggle-inr');
  var btnUSD = document.getElementById('mh-toggle-usd');
  var amounts = document.querySelectorAll('.mh-price-amount');

  function setCurrency(currency) {
    amounts.forEach(function(el) {
      el.textContent = el.getAttribute('data-' + currency);
    });
    if (currency === 'inr') {
      btnINR.classList.add('mh-toggle-active');
      btnUSD.classList.remove('mh-toggle-active');
    } else {
      btnUSD.classList.add('mh-toggle-active');
      btnINR.classList.remove('mh-toggle-active');
    }
  }

  btnINR.addEventListener('click', function() { setCurrency('inr'); });
  btnUSD.addEventListener('click', function() { setCurrency('usd'); });
})();
</script>