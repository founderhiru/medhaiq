}

function setupVoiceListeners() {
    // When the connection completes safely
    vapiInstance.on('call-start', () => {
        isCallLive = true;
        audioButton.disabled = false;
        audioButton.innerText = "End Call & Exit";
        audioButton.style.background = "#ef4444"; // Changes button red to signal an active line
        statusIndicator.innerText = "Interviewer is listening...";
    });

    // When the AI starts speaking, display a message or live subtitles
    vapiInstance.on('speech-start', () => {
        statusIndicator.innerText = "Interviewer speaking...";
    });

    vapiInstance.on('speech-end', () => {
        statusIndicator.innerText = "Your turn! Speak naturally.";
    });

    // When the interview ends or the user hangs up
    vapiInstance.on('call-end', () => {
        isCallLive = false;
        audioButton.disabled = false;
        audioButton.innerText = "Start Live Interview Voice";
        audioButton.style.background = "#4f46e5"; // Revert to standard branding color
        statusIndicator.innerText = "Session complete. Generating your scorecard...";
        
        // Gracefully forward them to your existing scorecard or history tab after 2 seconds
        setTimeout(() => {
            window.location.href = "/dashboard"; 
        }, 2000);
    });
}
</script>