<section class="mh-howitworks" id="how-it-works">
  <div class="mh-howitworks-inner">
    <div class="mh-section-eyebrow">How It Works</div>
    <h2 class="mh-section-headline">Three Steps to Career Transformation</h2>
    <p class="mh-howitworks-sub">Practice. Polish. Place. — a structured path from your first mock interview to your next career milestone.</p>

    <div class="mh-steps">
      <!-- SVG arc trajectory connecting all 3 steps -->
      <svg class="mh-steps-arc" viewBox="0 0 660 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M110 30 Q 220 10, 330 30" stroke="url(#arc-grad-1)" stroke-width="2" stroke-dasharray="6 4"/>
        <path d="M330 30 Q 440 50, 550 30" stroke="url(#arc-grad-2)" stroke-width="2" stroke-dasharray="6 4"/>
        <defs>
          <linearGradient id="arc-grad-1" x1="110" y1="30" x2="330" y2="30" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#059669"/>
            <stop offset="100%" stop-color="#3B82F6"/>
          </linearGradient>
          <linearGradient id="arc-grad-2" x1="330" y1="30" x2="550" y2="30" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#3B82F6"/>
            <stop offset="100%" stop-color="#7C3AED"/>
          </linearGradient>
        </defs>
      </svg>

      <!-- Step 01 — Emerald Green -->
      <div class="mh-step">
        <div class="mh-step-num">01</div>
        <div class="mh-step-icon mh-step-icon-emerald">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        </div>
        <h3 class="mh-step-title">Practice</h3>
        <p class="mh-step-desc">Run realistic mock interviews with AI personas calibrated to your target role. 6 expert styles, real pressure, zero judgment.</p>
      </div>

      <div class="mh-step-connector"></div>

      <!-- Step 02 — Royal Blue -->
      <div class="mh-step">
        <div class="mh-step-num">02</div>
        <div class="mh-step-icon mh-step-icon-blue">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3 class="mh-step-title">Polish</h3>
        <p class="mh-step-desc">Get a 5-vector scorecard — STAR structure, executive presence, technical depth, GCC readiness, friction signals. Know exactly what to fix.</p>
      </div>

      <div class="mh-step-connector"></div>

      <!-- Step 03 — Purple/Violet -->
      <div class="mh-step">
        <div class="mh-step-num">03</div>
        <div class="mh-step-icon mh-step-icon-purple">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 class="mh-step-title">Place</h3>
        <p class="mh-step-desc">Walk into your next interview with data-backed confidence. Track your trajectory across sessions and close the gap to your target role.</p>
      </div>
    </div>

    <!-- Step 03 scorecard CTAs -->
    <div class="mh-step-ctas">
      <button class="mh-step-cta-btn mh-step-cta-linkedin" id="mh-share-linkedin">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        Share to LinkedIn
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
      <button class="mh-step-cta-btn mh-step-cta-link" id="mh-copy-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <span id="mh-copy-label">Send Recruiter Link</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
(function() {
  var shareBtn = document.getElementById('mh-share-linkedin');
  var copyBtn = document.getElementById('mh-copy-link');
  var copyLabel = document.getElementById('mh-copy-label');

  if (shareBtn) {
    shareBtn.addEventListener('click', function() {
      var text = encodeURIComponent('I just tried MedhaIQ.ai — the AI Interview Intelligence platform. Built for Fortune 500 rubrics, global GCC leadership, and career-ready professionals. #AI #Interview #Career');
      var url = encodeURIComponent(window.location.href);
      window.open('https://www.linkedin.com/sharing/share-offsite/?url=' + url + '&summary=' + text, '_blank', 'width=600,height=480');
    });
  }

  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      var link = window.location.href;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(link).then(function() {
          copyLabel.textContent = 'Copied!';
          setTimeout(function() { copyLabel.textContent = 'Send Recruiter Link'; }, 2000);
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = link;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        copyLabel.textContent = 'Copied!';
        setTimeout(function() { copyLabel.textContent = 'Send Recruiter Link'; }, 2000);
      }
    });
  }
})();
</script>