<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — MedhaIQ</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/interview.css">
</head>
<body>

<div class="auth-page">
  <h1>Welcome to MedhaIQ</h1>
  <p class="subtitle">Sign in with your email to start practicing interviews.</p>

  <a href="/auth/google" class="auth-btn auth-btn-google">
    <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
    Sign in with Google
  </a>

  <div class="auth-or-divider"><span>or</span></div>

  <div class="auth-card">
    <label for="emailInput">Email address</label>
    <input type="email" id="emailInput" placeholder="you@company.com" autocomplete="email" />
    <label for="nameInput" style="margin-top:8px;">Your name (optional)</label>
    <input type="text" id="nameInput" placeholder="Firstname Lastname" autocomplete="name" />
    <button class="auth-btn" id="sendBtn">Send Magic Link</button>
    <div class="auth-msg" id="authMsg"></div>
  </div>

  <div class="auth-card" style="margin-top:16px;">
    <h3 style="font-size:16px;font-weight:600;color:#E2E8F0;margin-bottom:12px;">Or sign in with password</h3>
    <label for="passwordEmailInput">Email address</label>
    <input type="email" id="passwordEmailInput" placeholder="you@company.com" autocomplete="email" />
    <label for="passwordInput" style="margin-top:8px;">Password</label>
    <input type="password" id="passwordInput" placeholder="Minimum 8 characters" />
    <button class="auth-btn" id="passwordLoginBtn">Login with Password</button>
    <div class="auth-msg" id="passwordMsg"></div>
    <div style="margin-top:8px;text-align:center;">
      <a href="#" id="forgotPasswordLink" style="color:#3B82F6;font-size:13px;text-decoration:none;">Forgot password?</a>
      <div id="forgotPasswordMsg" style="color:#94A3B8;font-size:13px;margin-top:6px;display:none;">Please contact support to reset your password.</div>
    </div>
  </div>

  <div style="text-align:center;margin-top:24px;color:#94A3B8;font-size:14px;">
    Don't have an account? <a href="/auth/signup" style="color:#3B82F6;text-decoration:none;">Create one</a>
  </div>
</div>

<script>
(function() {
  // Magic link flow
  const emailInput = document.getElementById('emailInput');
  const nameInput = document.getElementById('nameInput');
  const sendBtn = document.getElementById('sendBtn');
  const msg = document.getElementById('authMsg');

  sendBtn.addEventListener('click', async function() {
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      msg.className = 'auth-msg error';
      msg.textContent = 'Please enter a valid email address.';
      return;
    }

    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending...';
    msg.className = 'auth-msg';
    msg.textContent = '';

    try {
      const resp = await fetch('/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, name: nameInput.value.trim() }),
      });
      const data = await resp.json();

      if (data.success) {
        msg.className = 'auth-msg success';
        msg.textContent = 'Magic link sent! Check your email and click the link to sign in.';
        sendBtn.textContent = 'Link Sent';
      } else {
        throw new Error(data.error || 'Failed to send link');
      }
    } catch (err) {
      msg.className = 'auth-msg error';
      msg.textContent = err.message || 'Something went wrong. Please try again.';
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send Magic Link';
    }
  });

  // Password login flow
  const passwordEmailInput = document.getElementById('passwordEmailInput');
  const passwordInput = document.getElementById('passwordInput');
  const passwordLoginBtn = document.getElementById('passwordLoginBtn');
  const passwordMsg = document.getElementById('passwordMsg');
  const forgotPasswordLink = document.getElementById('forgotPasswordLink');
  const forgotPasswordMsg = document.getElementById('forgotPasswordMsg');

  forgotPasswordLink.addEventListener('click', function(e) {
    e.preventDefault();
    forgotPasswordMsg.style.display = 'block';
  });

  passwordLoginBtn.addEventListener('click', async function() {
    const email = passwordEmailInput.value.trim();
    const password = passwordInput.value;

    if (!email || !email.includes('@')) {
      passwordMsg.className = 'auth-msg error';
      passwordMsg.textContent = 'Please enter a valid email address.';
      return;
    }
    if (!password || password.length < 8) {
      passwordMsg.className = 'auth-msg error';
      passwordMsg.textContent = 'Invalid email or password.';
      return;
    }

    passwordLoginBtn.disabled = true;
    passwordLoginBtn.textContent = 'Signing in...';
    passwordMsg.className = 'auth-msg';
    passwordMsg.textContent = '';

    try {
      const resp = await fetch('/auth/password-login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      const data = await resp.json();

      if (data.success) {
        window.location.href = '/interview';
      } else {
        throw new Error(data.error || 'Invalid email or password');
      }
    } catch (err) {
      passwordMsg.className = 'auth-msg error';
      passwordMsg.textContent = 'Invalid email or password.';
      passwordLoginBtn.disabled = false;
      passwordLoginBtn.textContent = 'Login with Password';
    }
  });
})();
</script>
</body>
</html>