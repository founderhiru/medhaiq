  <!-- Mobile menu -->
  <div class="mh-mobile-menu" id="mh-mobile-menu">
    <nav class="mh-mobile-nav">
      <a href="#platform" class="mh-mobile-link">Platform</a>
      <a href="#professional-horizons" class="mh-mobile-link">Solutions</a>
      <a href="#research" class="mh-mobile-link">Research</a>
