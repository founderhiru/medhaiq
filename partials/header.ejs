          <circle cx="10" cy="10" r="1.5" fill="white"/>
          <circle cx="3" cy="3" r="1.5" fill="white"/>
          <circle cx="17" cy="10" r="1.5" fill="white"/>
          <path d="M10 10 L17 3" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M7 14 L7 17 L10 17" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="mh-logo-text">Medha<span>IQ</span>.ai</span>
    </a>

    <!-- Desktop nav -->
    <nav class="mh-nav-links" aria-label="Main navigation">
      <a href="#platform" class="mh-nav-link">Platform</a>
      <a href="#professional-horizons" class="mh-nav-link">Solutions</a>
      <a href="#research" class="mh-nav-link">Research</a>
