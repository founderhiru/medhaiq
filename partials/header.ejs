    <!-- CTA + hamburger -->
    <div class="mh-nav-actions">
      <a href="/login" class="mh-nav-cta" style="margin-right: 8px;">Start Free Trial</a>
      <button class="mh-hamburger" id="mh-hamburger" aria-label="Toggle menu" aria-expanded="false">
