    </nav>
  </div>
</header>

<script>
(function() {
  var nav = document.getElementById('mh-nav');
  var hamburger = document.getElementById('mh-hamburger');
  var mobileMenu = document.getElementById('mh-mobile-menu');

  window.addEventListener('scroll', function() {
    if (window.scrollY > 60) {
      nav.classList.add('mh-nav-scrolled');
    } else {
      nav.classList.remove('mh-nav-scrolled');
    }
  });

  hamburger.addEventListener('click', function() {
    var isOpen = mobileMenu.classList.toggle('mh-mobile-menu-open');
    hamburger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    hamburger.classList.toggle('mh-hamburger-open', isOpen);
  });

  mobileMenu.querySelectorAll('a').forEach(function(link) {
    link.addEventListener('click', function() {
      mobileMenu.classList.remove('mh-mobile-menu-open');
      hamburger.classList.remove('mh-hamburger-open');
      hamburger.setAttribute('aria-expanded', 'false');
    });
  });
})();
</script>