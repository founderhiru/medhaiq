  <!-- Scroll reveal: IntersectionObserver for .reveal elements -->
  <script>
  (function() {
    var reveals = document.querySelectorAll('.reveal');
    if (!reveals.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          var items = entry.target.querySelectorAll('.reveal-item');
          items.forEach(function(item, i) {
            setTimeout(function() { item.classList.add('visible'); }, i * 100);
          });
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach(function(el) { observer.observe(el); });
  })();
  </script>

  <!-- Global modal trigger — opens the email capture modal from any page -->
  <script>
  (function() {
    function openModal(plan) {
      var modal = document.getElementById('mh-email-modal');
      if (!modal) return;
      modal.style.display = 'flex';
      var planField = document.getElementById('mh-modal-plan');
      if (planField) planField.value = plan || 'free';
      var form = document.getElementById('mh-modal-form');
      if (form) form.style.display = 'flex';
      var success = document.getElementById('mh-modal-success');
      if (success) success.style.display = 'none';
    }
    // Wire all .mh-open-modal buttons (hero, nav CTAs)
    document.querySelectorAll('.mh-open-modal').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openModal(btn.getAttribute('data-plan') || 'free');
      });
    });
    // Close handlers
    var closeBtn = document.getElementById('mh-modal-close');
    var modal = document.getElementById('mh-email-modal');
    if (closeBtn) closeBtn.addEventListener('click', function() {
      if (modal) modal.style.display = 'none';
    });
    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === modal) modal.style.display = 'none';
      });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
        modal.style.display = 'none';
      }
    });
  })();
  </script>

  <!-- Polsia Analytics Beacon -->
  <script>
    (function() {
      var slug = 'medhaiq';
      var vid = localStorage.getItem('polsia_vid');
      if (!vid) {
        vid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
          var r = Math.random() * 16 | 0;
          return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
        });
        localStorage.setItem('polsia_vid', vid);
      }
      new Image().src = 'https://polsia.com/api/beacon/pixel?s=' + encodeURIComponent(slug) + '&v=' + encodeURIComponent(vid);
    })();
  </script>

  <!-- Contact Form Modal -->
  <div class="mh-contact-modal-overlay" id="mh-contact-modal" style="display:none">
    <div class="mh-contact-modal">
      <button class="mh-contact-modal-close" id="mh-contact-close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="mh-contact-modal-title">Get in touch</div>
      <div class="mh-contact-modal-sub">We'll get back to you within 1 business day.</div>
      <div class="mh-contact-success" id="mh-contact-success" style="display:none">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Message sent! We'll be in touch soon.</span>
      </div>
      <form class="mh-contact-form" id="mh-contact-form">
        <div class="mh-contact-field">
          <label for="ct-name">Name <span>*</span></label>
          <input type="text" id="ct-name" placeholder="Your name" required autocomplete="name">
        </div>
        <div class="mh-contact-field">
          <label for="ct-email">Email <span>*</span></label>
          <input type="email" id="ct-email" placeholder="you@company.com" required autocomplete="email">
        </div>
        <div class="mh-contact-field">
          <label for="ct-message">Message <span>*</span></label>
          <textarea id="ct-message" placeholder="How can we help?" required rows="4"></textarea>
        </div>
        <button type="submit" class="mh-contact-submit" id="mh-contact-submit">Send Message</button>
      </form>
    </div>
  </div>

  <script>
  (function() {
    var contactBtn = document.getElementById('mh-contact-btn');
    var contactModal = document.getElementById('mh-contact-modal');
    var contactClose = document.getElementById('mh-contact-close');
    var contactForm = document.getElementById('mh-contact-form');
    var contactSuccess = document.getElementById('mh-contact-success');
    var contactSubmit = document.getElementById('mh-contact-submit');

    if (contactBtn && contactModal) {
      contactBtn.addEventListener('click', function() {
        contactModal.style.display = 'flex';
        contactForm.style.display = 'flex';
        if (contactSuccess) contactSuccess.style.display = 'none';
      });
    }
    if (contactClose) {
      contactClose.addEventListener('click', function() {
        contactModal.style.display = 'none';
      });
    }
    if (contactModal) {
      contactModal.addEventListener('click', function(e) {
        if (e.target === contactModal) contactModal.style.display = 'none';
      });
    }
    if (contactForm) {
      contactForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        contactSubmit.disabled = true;
        contactSubmit.textContent = 'Sending...';
        var name = document.getElementById('ct-name').value.trim();
        var email = document.getElementById('ct-email').value.trim();
        var message = document.getElementById('ct-message').value.trim();
        if (!name || !email || !message) {
          contactSubmit.disabled = false;
          contactSubmit.textContent = 'Send Message';
          return;
        }
        try {
          var res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, email: email, message: message })
          });
          var json = await res.json();
          if (json.success) {
            contactForm.style.display = 'none';
            contactForm.reset();
            contactSubmit.disabled = false;
            contactSubmit.textContent = 'Send Message';
            if (contactSuccess) {
              contactSuccess.style.display = 'flex';
              setTimeout(function() { contactModal.style.display = 'none'; }, 3000);
            }
          } else {
            contactSubmit.disabled = false;
            contactSubmit.textContent = 'Send Message';
            alert(json.error || 'Failed to send message. Please try again.');
          }
        } catch(err) {
          contactSubmit.disabled = false;
          contactSubmit.textContent = 'Send Message';
          alert('Network error. Please try again.');
        }
      });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && contactModal && contactModal.style.display === 'flex') {
        contactModal.style.display = 'none';
      }
    });
  })();
  </script>
