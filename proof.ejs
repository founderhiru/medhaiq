<!-- Section 10: Product Proof Grid (CSS/JS — NO video) -->
<section class="mh-proof reveal" id="proof">
  <div class="mh-proof-inner">
    <div class="mh-section-center">
      <div class="mh-eyebrow">Live Engine</div>
      <h2 class="mh-section-title">Engineered for Certainty. Built with Precision.</h2>
      <p class="mh-section-sub">Live previews of the interview engine, scoring system, and performance intelligence dashboard.</p>
    </div>

    <div class="mh-proof-grid">

      <!-- Panel 1: Interview in Progress -->
      <div class="mh-proof-panel">
        <div class="mh-proof-panel-label">
          <span class="dot dot-emerald"></span>
          AI Interviewer — McKinsey Consulting Persona
        </div>
        <div class="mh-proof-content" id="mh-proof-1">
          <div class="mh-interview-q" id="mh-proof-q"></div>
          <div class="mh-interview-ans" id="mh-proof-ans"></div>
        </div>
      </div>

      <!-- Panel 2: Real-Time Scoring -->
      <div class="mh-proof-panel">
        <div class="mh-proof-panel-label">
          <span class="dot dot-blue"></span>
          5-Vector Live Scoring
        </div>
        <div class="mh-proof-content">
          <div class="mh-score-bars">
            <div class="mh-score-bar-row">
              <span class="mh-score-bar-label">STAR Competency</span>
              <div class="mh-score-bar-track">
                <div class="mh-score-bar-fill" id="mh-bar-star"></div>
              </div>
              <span class="mh-score-bar-num" id="mh-bar-star-val">0</span>
            </div>
            <div class="mh-score-bar-row">
              <span class="mh-score-bar-label">Executive Presence</span>
              <div class="mh-score-bar-track">
                <div class="mh-score-bar-fill" id="mh-bar-pres"></div>
              </div>
              <span class="mh-score-bar-num" id="mh-bar-pres-val">0</span>
            </div>
            <div class="mh-score-bar-row">
              <span class="mh-score-bar-label">Technical Depth</span>
              <div class="mh-score-bar-track">
                <div class="mh-score-bar-fill gold-fill" id="mh-bar-tech"></div>
              </div>
              <span class="mh-score-bar-num gold" id="mh-bar-tech-val">0</span>
            </div>
          </div>
          <div class="mh-filler-counter">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Filler Words Detected: <strong id="mh-filler-count">0</strong>
          </div>
        </div>
      </div>

      <!-- Panel 3: Exit Report -->
      <div class="mh-proof-panel">
        <div class="mh-proof-panel-label">
          <span class="dot dot-gold"></span>
          Post-Interview Scorecard
        </div>
        <div class="mh-proof-content">
          <div class="mh-report-wrap">
            <div class="mh-report-score-ring">
              <svg width="80" height="80" viewBox="0 0 80 80">
                <circle cx="40" cy="40" r="34" fill="none" stroke="var(--navy-border)" stroke-width="5"/>
                <circle cx="40" cy="40" r="34" fill="none" stroke="var(--gold)" stroke-width="5"
                  stroke-dasharray="214" stroke-dashoffset="36"
                  id="mh-report-ring"/>
              </svg>
              <div class="mh-report-score-inner">
                <span class="mh-report-score-num" id="mh-report-score">83</span>
                <span class="mh-report-score-label">Overall</span>
              </div>
            </div>
            <div class="mh-report-points">
              <div class="mh-report-point" id="mh-rp-1">Strengthen P&L narrative with quantified outcomes</div>
              <div class="mh-report-point" id="mh-rp-2">Reduce filler words by 40% — focus on precision</div>
              <div class="mh-report-point" id="mh-rp-3">Deepen stakeholder mapping section for board-level answers</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel 4: Performance Trend -->
      <div class="mh-proof-panel">
        <div class="mh-proof-panel-label">
          <span class="dot dot-blue"></span>
          Session Progress Tracking
        </div>
        <div class="mh-proof-content">
          <div class="mh-trend-svg-wrap" id="mh-trend-svg">
            <svg viewBox="0 0 280 90" preserveAspectRatio="xMidYMid meet">
              <defs>
                <linearGradient id="trendGradient" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="rgba(59,130,246,0.3)"/>
                  <stop offset="100%" stop-color="rgba(59,130,246,0.0)"/>
                </linearGradient>
              </defs>
              <!-- Area fill -->
              <path class="mh-trend-area" id="mh-trend-area"
                d="M30,75 L95,58 L160,42 L225,20 L225,88 L30,88 Z"/>
              <!-- Line -->
              <path class="mh-trend-line" id="mh-trend-line"
                d="M30,75 L95,58 L160,42 L225,20"/>
              <!-- Dots + labels -->
              <circle class="mh-trend-dot" id="mh-dot-1" cx="30" cy="75"/>
              <text class="mh-trend-label" x="30" y="88">S1</text>
              <text class="mh-trend-val" x="30" y="68">61</text>

              <circle class="mh-trend-dot" id="mh-dot-2" cx="95" cy="58"/>
              <text class="mh-trend-label" x="95" y="88">S2</text>
              <text class="mh-trend-val" x="95" y="51">72</text>

              <circle class="mh-trend-dot" id="mh-dot-3" cx="160" cy="42"/>
              <text class="mh-trend-label" x="160" y="88">S3</text>
              <text class="mh-trend-val" x="160" y="35">79</text>

              <circle class="mh-trend-dot" id="mh-dot-4" cx="225" cy="20"/>
              <text class="mh-trend-label" x="225" y="88">S4</text>
              <text class="mh-trend-val" x="225" y="13">83</text>
            </svg>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  // Scroll reveal + proof animations
  var proofSection = document.querySelector('.mh-proof');
  if (!proofSection) return;

  var proofStarted = false;

  function startProofAnimations() {
    if (proofStarted) return;
    proofStarted = true;

    // Panel 2: Score bars animate left-to-right
    setTimeout(function() {
      var starFill = document.getElementById('mh-bar-star');
      var presFill = document.getElementById('mh-bar-pres');
      var techFill = document.getElementById('mh-bar-tech');
      var starVal = document.getElementById('mh-bar-star-val');
      var presVal = document.getElementById('mh-bar-pres-val');
      var techVal = document.getElementById('mh-bar-tech-val');
      var filler = document.getElementById('mh-filler-count');

      if (starFill) {
        starFill.style.width = '84%';
        starVal.textContent = '84';
        setTimeout(function() {
          presFill.style.width = '77%';
          presVal.textContent = '77';
        }, 200);
        setTimeout(function() {
          techFill.style.width = '91%';
          techVal.textContent = '91';
        }, 400);
        setTimeout(function() {
          var count = 0;
          var fi = setInterval(function() {
            if (count < 2) {
              count++;
              filler.textContent = count;
            } else {
              clearInterval(fi);
            }
          }, 300);
        }, 800);
      }
    }, 600);

    // Panel 3: Report points stagger in
    setTimeout(function() {
      var pts = [
        document.getElementById('mh-rp-1'),
        document.getElementById('mh-rp-2'),
        document.getElementById('mh-rp-3')
      ];
      pts.forEach(function(p, i) {
        if (p) {
          setTimeout(function() { p.classList.add('show'); }, i * 300);
        }
      });

      // Animate ring
      var ring = document.getElementById('mh-report-ring');
      if (ring) {
        ring.style.strokeDashoffset = 214;
        requestAnimationFrame(function() {
          ring.style.strokeDashoffset = 36;
        });
      }
    }, 800);

    // Panel 4: SVG trend line draws
    setTimeout(function() {
      var line = document.getElementById('mh-trend-line');
      var area = document.getElementById('mh-trend-area');
      var dots = [
        document.getElementById('mh-dot-1'),
        document.getElementById('mh-dot-2'),
        document.getElementById('mh-dot-3'),
        document.getElementById('mh-dot-4')
      ];
      if (line) line.classList.add('animated');
      if (area) area.classList.add('animated');
      dots.forEach(function(d, i) {
        if (d) {
          setTimeout(function() { d.classList.add('animated'); }, 300 + i * 400);
        }
      });
    }, 600);
  }

  // Panel 1: Typewriter animation
  var proofQuestions = [
    "Walk me through a complex stakeholder alignment challenge where the outcome was uncertain.",
    "Describe a time you led a team through a significant organisational change.",
    "How would you structure a presentation for a board-level audience?"
  ];
  var proofAns = "I approach this by first establishing the key decision-makers and their underlying interests. From there, I build a structured narrative that connects the problem to measurable business outcomes, using data to anchor each claim...";

  var qEl = document.getElementById('mh-proof-q');
  var aEl = document.getElementById('mh-proof-ans');

  function typeTo(el, text, speed, cb) {
    var chars = text.split('');
    var i = 0;
    function tick() {
      if (i < chars.length) {
        el.textContent += chars[i];
        i++;
        setTimeout(tick, speed);
      } else if (cb) {
        setTimeout(cb, speed);
      }
    }
    tick();
  }

  function runProofLoop() {
    if (qEl) qEl.textContent = '';
    if (aEl) aEl.textContent = '';
    var q = proofQuestions[Math.floor(Math.random() * proofQuestions.length)];

    setTimeout(function() {
      typeTo(qEl, q, 25, function() {
        setTimeout(function() {
          typeTo(aEl, proofAns, 18, function() {
            setTimeout(runProofLoop, 3000);
          });
        }, 500);
      });
    }, 500);
  }

  var proofObserved = false;
  var proofObs = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting && !proofObserved) {
      proofObserved = true;
      setTimeout(function() {
        startProofAnimations();
        runProofLoop();
      }, 400);
    }
  }, { threshold: 0.2 });

  proofObs.observe(proofSection);
})();
</script>